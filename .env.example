# ── App ──────────────────────────────────────────
APP_PORT=8080
APP_ENV=development          # development | production
APP_LOG_LEVEL=debug          # debug | info | warn | error
FRONTEND_URL=http://localhost:3000  # Frontend base URL for OAuth redirects

# ── PostgreSQL ───────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=anagram
POSTGRES_USER=anagram
POSTGRES_PASSWORD=secret
POSTGRES_SSLMODE=disable
POSTGRES_MAX_CONNS=20
POSTGRES_EXTERNAL_PORT=5432  # host port mapping

# ── Redis ────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=secret
REDIS_DB=0
REDIS_EXTERNAL_PORT=6379     # host port mapping

# ── Dictionary ───────────────────────────────────
DICT_PATH=./dictionaries     # directory with en.txt, ru.txt
DICT_LANGUAGES=ru,en         # languages to load at startup

# ── Game defaults ────────────────────────────────
GAME_DEFAULT_TIME_LIMIT=60   # seconds
GAME_DEFAULT_LETTER_COUNT=7
GAME_MIN_WORD_LENGTH=3

# ── Rate limiting ────────────────────────────────
RATE_LIMIT_RPS=10            # requests per second per IP
RATE_LIMIT_BURST=20

# ── Telegram Auth ────────────────────────────────
# Create bot via @BotFather and get bot token
# Set domain for Login Widget via /setdomain in @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
VITE_TELEGRAM_BOT_USERNAME=your_bot_username_here

# ── JWT ──────────────────────────────────────────
JWT_SECRET=your_random_secret_key_here_use_openssl_rand_base64_64
JWT_ACCESS_TTL=15m           # Access token lifetime (e.g., 15m, 1h)
JWT_REFRESH_TTL=168h         # Refresh token lifetime (e.g., 168h = 7 days)