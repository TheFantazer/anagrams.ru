# ── App ──────────────────────────────────────────
APP_PORT=8080
APP_ENV=development          # development | production
APP_LOG_LEVEL=debug          # debug | info | warn | error

# ── PostgreSQL ───────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=anagram
POSTGRES_USER=anagram
POSTGRES_PASSWORD=secret
POSTGRES_SSLMODE=disable
POSTGRES_MAX_CONNS=20
POSTGRES_EXTERNAL_PORT=5432  # host port mapping

# ── Redis ────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=secret
REDIS_DB=0
REDIS_EXTERNAL_PORT=6379     # host port mapping

# ── Dictionary ───────────────────────────────────
DICT_PATH=./dictionaries     # directory with en.txt, ru.txt
DICT_LANGUAGES=ru,en         # languages to load at startup

# ── Game defaults ────────────────────────────────
GAME_DEFAULT_TIME_LIMIT=60   # seconds
GAME_DEFAULT_LETTER_COUNT=7
GAME_MIN_WORD_LENGTH=3

# ── Rate limiting ────────────────────────────────
RATE_LIMIT_RPS=10            # requests per second per IP
RATE_LIMIT_BURST=20